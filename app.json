{
  "expo": {
    "name": "ShopManager",
    "slug": "ShopManager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "shopmanager",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shopmanager.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.shopmanager.app",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ShopManager to access your camera for barcode scanning."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow ShopManager to access your photos for product images."
        }
      ]
    ]
  }
}
